{
    "name": "iot-platform",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "server",
        "packages/*"
    ],
    "scripts": {
        "build": "npm run build:contracts && npm run build:server && npm run build:contracts",
        "build:contracts": "npm run build --workspace @iot/contracts",
        "build:server": "npm run build --workspace @iot/server",
        "dev:server": "npm run dev --workspace @iot/server",
        "typecheck": "npm run typecheck --workspace --if-present"
    }
}